<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.grocery.controller.SettingsController"
            fitToWidth="true" hbarPolicy="NEVER"
            styleClass="page-scroll-root">

    <VBox styleClass="page-root" spacing="16">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Settings" styleClass="page-title"/>

        <HBox spacing="16">

            <!-- Shop Info -->
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10">
                <Label text="Shop Information" styleClass="card-title"/>
                <VBox spacing="5"><Label text="Shop Name" styleClass="field-label"/>
                    <TextField fx:id="fldShopName" promptText="Your shop name" styleClass="input-field"/></VBox>
                <VBox spacing="5"><Label text="Owner Name" styleClass="field-label"/>
                    <TextField fx:id="fldOwnerName" promptText="Owner / Manager name" styleClass="input-field"/></VBox>
                <VBox spacing="5"><Label text="Address" styleClass="field-label"/>
                    <TextField fx:id="fldAddress" promptText="Shop address" styleClass="input-field"/></VBox>
                <VBox spacing="5"><Label text="Phone Number" styleClass="field-label"/>
                    <TextField fx:id="fldPhone" promptText="Contact number" styleClass="input-field"/></VBox>
                <VBox spacing="5"><Label text="GST Number (optional)" styleClass="field-label"/>
                    <TextField fx:id="fldGstNumber" promptText="e.g. 22AAAAA0000A1Z5" styleClass="input-field"/></VBox>

                <Separator/>
                <Label text="Billing Preferences" styleClass="card-title"/>
                <HBox spacing="10">
                    <VBox HBox.hgrow="ALWAYS" spacing="5"><Label text="Currency Symbol" styleClass="field-label"/>
                        <TextField fx:id="fldCurrency" text="₹" styleClass="input-field"/></VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="5"><Label text="Default GST %" styleClass="field-label"/>
                        <TextField fx:id="fldGstRate" text="0" styleClass="input-field"/></VBox>
                </HBox>
                <VBox spacing="5"><Label text="Low Stock Alert (units)" styleClass="field-label"/>
                    <TextField fx:id="fldLowStockThreshold" text="10" styleClass="input-field"/></VBox>

                <Label fx:id="settingsStatusLabel" wrapText="true" maxWidth="Infinity"/>

                <Button text="💾  Save Settings" onAction="#handleSaveSettings"
                        styleClass="btn-primary" maxWidth="Infinity" prefHeight="42"/>
            </VBox>

            <!-- Change Password -->
            <VBox styleClass="card" prefWidth="320" minWidth="300" spacing="10">
                <Label text="Change Password" styleClass="card-title"/>
                <VBox spacing="5"><Label text="Current Password" styleClass="field-label"/>
                    <PasswordField fx:id="fldOldPassword" promptText="Enter current password" styleClass="input-field"/></VBox>
                <VBox spacing="5"><Label text="New Password" styleClass="field-label"/>
                    <PasswordField fx:id="fldNewPassword" promptText="At least 6 characters" styleClass="input-field"/></VBox>
                <VBox spacing="5"><Label text="Confirm New Password" styleClass="field-label"/>
                    <PasswordField fx:id="fldConfirmPassword" promptText="Repeat new password" styleClass="input-field"/></VBox>

                <Label fx:id="passwordStatusLabel" wrapText="true" maxWidth="280"/>

                <Button text="🔑  Change Password" onAction="#handleChangePassword"
                        styleClass="btn-primary" maxWidth="Infinity" prefHeight="42"/>

                <Separator/>
                <Label text="Application Info" styleClass="card-title"/>
                <VBox spacing="4">
                    <Label text="Grocery Shop Management System" styleClass="app-info-label"/>
                    <Label text="Version 1.0.0" styleClass="app-info-label-dim"/>
                    <Label text="Built with JavaFX + SQLite" styleClass="app-info-label-dim"/>
                    <Label text="All data stored locally — No internet required" styleClass="app-info-label-dim"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
